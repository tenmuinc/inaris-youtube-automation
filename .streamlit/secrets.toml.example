# Streamlit Secrets サンプル
#
# Streamlit Cloudではアプリ設定 → Secrets にこの内容を貼り付ける。
# ローカル動作確認したい場合は `.streamlit/secrets.toml` (gitignore済) として保存。

# ----- Anthropic -----
anthropic_api_key = "sk-ant-XXXXXXXXXXXX"
anthropic_model = "claude-sonnet-4-6"

# ----- Google OAuth -----
# Google Cloud Console で作成した「ウェブアプリケーション」用OAuthクライアントのJSONから転記する。
# (ダウンロードしたJSONの "web" セクションの中身)
[google_oauth]
client_id = "XXXXX.apps.googleusercontent.com"
client_secret = "GOCSPX-XXXXXXXXXXXX"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"

# このアプリのデプロイ先URL。末尾スラッシュなし。Google Cloud Console側にも同じURLをリダイレクトURIとして登録する。
# 例: "https://inaris-youtube-automation.streamlit.app"
# ローカル動作確認時: "http://localhost:8501"
redirect_uri = "https://your-app.streamlit.app"

# ----- Claudeプロンプト -----
# INARISのコンテンツ作成ノウハウなのでリポジトリには入れず、Streamlit Secretsに置く。
# 値は実際のmarkdown全文 (改行・記号そのまま)。トリプルクォートで囲む。
[prompts]
native_vibe = """
（ここに native_vibe.md の中身を全文ペースト）
"""

jlpt = """
（ここに jlpt.md の中身を全文ペースト）
"""

multilingual_titles = """
（ここに multilingual_titles.md の中身を全文ペースト）
"""

# ----- 21言語のVrew命名規則 -----
